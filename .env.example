# LLM Configuration
# Set ARIA_MODEL to your desired model. Examples:
# - OpenAI: gpt-4o
# - Gemini: gemini/gemini-1.5-pro
# - OpenRouter: openrouter/anthropic/claude-3-opus
# - DeepSeek: deepseek/deepseek-chat
# - Copilot-API / Local Proxy: openai/gpt-4 (and set API_BASE below)
# - Ollama: ollama/llama3 (and set API_BASE below)
ARIA_MODEL=gpt-4o

# API Keys (Set the ones you use, leave others blank)
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Base URL
# Use for local Ollama (http://localhost:11434), LM Studio, or Copilot-API (http://localhost:4141)
# API_BASE=http://localhost:4141
# Server
ARIA_HOST=0.0.0.0
ARIA_PORT=8000

# Memory
CHROMA_PERSIST_DIR=./memory/chroma_db

# Email (Optional)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Scheduler
# SCHEDULER_DB_PATH=./data/scheduler.db

# Notifications — Slack (Incoming Webhook URL)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Notifications — Telegram (Bot Token from @BotFather + your Chat ID)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_CHAT_ID=your_chat_id

# Notifications — WhatsApp via Twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=+14155238886
# TWILIO_WHATSAPP_TO=+1234567890

# Notifications — Discord (Webhook URL from channel settings)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY
